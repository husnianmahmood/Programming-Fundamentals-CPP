#include <iostream>
using namespace std;

void printVertical(char word[], int size) {
    for (int i = 0; i < size; i++) {
        cout << word[i] << endl;
    }
}

int main() {
    int size;
    char word[100];

    cout << "    Vertical Billboard Generator    " << endl;
    cout << "Enter the number of letters in your word: ";
    cin >> size;
    cout << "Enter the word (no spaces): ";
    cin >> word;

    cout << "\nHere is your billboard:" << endl;
    cout << endl;
    printVertical(word, size);
    cout << endl;

    return 0;
}
