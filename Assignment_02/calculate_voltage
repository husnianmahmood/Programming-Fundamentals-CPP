#include <iostream>
using namespace std;

double calculateVoltage(double current, double resistance) {
    return current * resistance;
}

int main() {
    double current, resistance;
    cout << "Enter Current: ";
    cin >> current;
    cout << "Enter Resistance: ";
    cin >> resistance;

    cout << "Voltage is: " << calculateVoltage(current, resistance) << " V" << endl;
    return 0;
}
