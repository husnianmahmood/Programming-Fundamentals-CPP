#include <iostream>
using namespace std;

double calculateStrikeRate(int runs, int balls) {
    double strikeRate = ((double)runs / balls) * 100;
    return strikeRate;
}

int main() {
    int run, balls;
    cout << "Run: " << endl;
    cin >> run;
    cout << "Balls: " << endl;
    cin >> balls;

    double result = calculateStrikeRate(run, balls);
    cout << "Strike rate is: " << result << endl;

    return 0;
}
