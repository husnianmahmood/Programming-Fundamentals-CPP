#include <iostream>
using namespace std;

int getLength(char arr[]) {
    int length = 0;
    for (int i = 0; arr[i] != '\0'; i++) {
        length++;
    }
    return length;
}

int main() {
    char name[] = "I am learning python from the online sources";
    cout << getLength(name) << endl;
    return 0;
}
