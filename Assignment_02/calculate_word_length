#include <iostream>
using namespace std;

int findLength(char word[]) {
    int count = 0;
    while (word[count] != '\0') {
        count++;
    }
    return count;
}

int main() {
    char word[100];
    cout << "Enter Your Word: ";
    cin >> word;

    cout << "Length of the word is: " << findLength(word) << endl;
    return 0;
}
